<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title><%= listing.book.title %></title>
</head>
<body>
 <%- include('partials/nav') %>

 <h1><%= listing.book.title %></h1>
 <p>著者: <%= listing.book.author %></p>
 <% if (listing.book.publisher) { %><p>出版社: <%= listing.book.publisher %></p><% } %>
 <% if (listing.book.edition) { %><p>版: <%= listing.book.edition %></p><% } %>
 <% if (listing.book.isbn) { %><p>ISBN: <%= listing.book.isbn %></p><% } %>

 <p>状態: <%= listing.condition %></p>
 <p>ステータス: <%= listing.status %></p>

 <% if (listing.listingType === 'FIXED') { %>
   <p>価格: <%= listing.price %>円</p>
 <% } else { %>
   <p>現在価格: <%= listing.currentPrice %>円(開始価格 <%= listing.startingPrice %>円)</p>
   <p>終了日時: <%= listing.auctionEndAt.toLocaleString('ja-JP') %></p>

   <% if (listing.status === 'SOLD' && listing.winner) { %>
     <p>落札者: <%= listing.winner.name %></p>
   <% } else if (listing.status === 'CANCELLED') { %>
     <p>入札がなかったため不成立となりました。</p>
   <% } %>
 <% } %>

 <% if (listing.description) { %>
   <p><%= listing.description %></p>
 <% } %>

 <p>出品者: <%= listing.seller.name %></p>

 <% if (currentUser && currentUser.id !== listing.sellerId) { %>
   <form action="/listings/<%= listing.id %>/conversations" method="post" style="display:inline">
     <button type="submit">出品者に質問する</button>
   </form>
 <% } else if (!currentUser) { %>
   <p>出品者に質問するには<a href="/login">ログイン</a>してください。</p>
 <% } %>

 <% if (listing.listingType === 'AUCTION') { %>
   <h2>入札履歴</h2>
   <% if (listing.bids.length === 0) { %>
     <p>まだ入札がありません。</p>
   <% } else { %>
     <ul>
       <% listing.bids.forEach(bid => { %>
         <li><%= bid.bidder.name %>: <%= bid.amount %>円(<%= bid.createdAt.toLocaleString('ja-JP') %>)</li>
       <% }) %>
     </ul>
   <% } %>

   <% if (error) { %>
     <p style="color:red"><%= error %></p>
   <% } %>

   <% if (currentUser && listing.status === 'ACTIVE' && currentUser.id !== listing.sellerId) { %>
     <form action="/listings/<%= listing.id %>/bids" method="post">
       <input type="number" name="amount" min="<%= listing.currentPrice + 1 %>" placeholder="入札額(<%= listing.currentPrice %>円より高い金額)" required>
       <button type="submit">入札する</button>
     </form>
   <% } else if (!currentUser) { %>
     <p>入札するには<a href="/login">ログイン</a>してください。</p>
   <% } %>
 <% } %>

 <p><a href="/listings">出品一覧に戻る</a></p>

</body>
</html>
