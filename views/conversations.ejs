<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>会話一覧</title>
</head>
<body>
 <%- include('partials/nav') %>

 <h1>会話一覧</h1>

 <% if (conversations.length === 0) { %>
   <p>まだ会話がありません。</p>
 <% } else { %>
   <ul>
     <% conversations.forEach(c => { %>
       <li>
         <a href="/conversations/<%= c.id %>">
           [<%= c.isSeller ? '出品者として' : '質問者として' %>]
           <%= c.listing.book.title %> — <%= c.isSeller ? c.buyer.name : c.listing.seller.name %>さん
         </a>
         <br>
         <% if (c.messages[0]) { %>
           <%= c.messages[0].body.slice(0, 40) %>(<%= c.lastMessageAt.toLocaleString('ja-JP') %>)
         <% } else { %>
           まだメッセージがありません(<%= c.lastMessageAt.toLocaleString('ja-JP') %>)
         <% } %>
       </li>
     <% }) %>
   </ul>
 <% } %>

</body>
</html>
