<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>出品一覧</title>
</head>
<body>
 <%- include('partials/nav') %>

 <h1>出品一覧</h1>

 <% if (currentUser) { %>
   <p><a href="/listings/new">出品する</a></p>
 <% } else { %>
   <p>出品するには<a href="/login">ログイン</a>してください。</p>
 <% } %>

 <form action="/listings" method="get">
  <input type="text" name="q" placeholder="タイトル・著者で検索" value="<%= filters.q %>">

  <select name="courseId">
    <option value="">すべての授業</option>
    <% courses.forEach(course => { %>
      <option value="<%= course.id %>" <%= String(filters.courseId) === String(course.id) ? 'selected' : '' %>>
        <%= course.name %><% if (course.year || course.term) { %> (<%= [course.year, course.term].filter(Boolean).join(' ') %>)<% } %>
      </option>
    <% }) %>
  </select>

  <select name="condition">
    <option value="">すべての状態</option>
    <% conditions.forEach(c => { %>
      <option value="<%= c %>" <%= filters.condition === c ? 'selected' : '' %>><%= c %></option>
    <% }) %>
  </select>

  <select name="listingType">
    <option value="">すべての形式</option>
    <option value="FIXED" <%= filters.listingType === 'FIXED' ? 'selected' : '' %>>販売形式</option>
    <option value="AUCTION" <%= filters.listingType === 'AUCTION' ? 'selected' : '' %>>オークション形式</option>
  </select>

  <input type="number" name="minPrice" placeholder="価格下限" value="<%= filters.minPrice ?? '' %>">
  <input type="number" name="maxPrice" placeholder="価格上限" value="<%= filters.maxPrice ?? '' %>">

  <button type="submit">絞り込む</button>
  <a href="/listings">条件をクリア</a>
 </form>

 <ul>
  <% listings.forEach(listing => { %>
    <li>
      <a href="/listings/<%= listing.id %>"><%= listing.book.title %></a>
      / <%= listing.book.author %>
      / <% if (listing.listingType === 'FIXED') { %>
          <%= listing.price %>円
        <% } else { %>
          現在 <%= listing.currentPrice %>円(オークション)
        <% } %>
      / 状態: <%= listing.condition %>
      / 出品者: <%= listing.seller.name %>
    </li>
  <% }) %>
 </ul>

 <p><a href="/books">教科書マスタを見る</a></p>

</body>
</html>
