<%- include('partials/head', { title: '出品一覧' }) %>

 <h1>出品一覧</h1>

 <% if (currentUser) { %>
   <p><a href="/listings/new" class="btn">出品する</a></p>
 <% } else { %>
   <p>出品するには<a href="/login">ログイン</a>してください。</p>
 <% } %>

 <form action="/listings" method="get" class="filter-form">
  <div class="field">
    <label for="q">キーワード</label>
    <input id="q" type="text" name="q" placeholder="タイトル・著者で検索" value="<%= filters.q %>">
  </div>

  <div class="field">
    <label for="courseId">授業</label>
    <select id="courseId" name="courseId">
      <option value="">すべての授業</option>
      <% courses.forEach(course => { %>
        <option value="<%= course.id %>" <%= String(filters.courseId) === String(course.id) ? 'selected' : '' %>>
          <%= course.name %><% if (course.year || course.term) { %> (<%= [course.year, course.term].filter(Boolean).join(' ') %>)<% } %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="field">
    <label for="condition">状態</label>
    <select id="condition" name="condition">
      <option value="">すべての状態</option>
      <% conditions.forEach(c => { %>
        <option value="<%= c %>" <%= filters.condition === c ? 'selected' : '' %>><%= c %></option>
      <% }) %>
    </select>
  </div>

  <div class="field">
    <label for="listingType">形式</label>
    <select id="listingType" name="listingType">
      <option value="">すべての形式</option>
      <option value="FIXED" <%= filters.listingType === 'FIXED' ? 'selected' : '' %>>販売形式</option>
      <option value="AUCTION" <%= filters.listingType === 'AUCTION' ? 'selected' : '' %>>オークション形式</option>
    </select>
  </div>

  <div class="field">
    <label for="minPrice">価格(下限)</label>
    <input id="minPrice" type="number" name="minPrice" placeholder="円" value="<%= filters.minPrice ?? '' %>">
  </div>

  <div class="field">
    <label for="maxPrice">価格(上限)</label>
    <input id="maxPrice" type="number" name="maxPrice" placeholder="円" value="<%= filters.maxPrice ?? '' %>">
  </div>

  <div class="filter-actions">
    <button type="submit" class="btn">絞り込む</button>
    <a href="/listings">条件をクリア</a>
  </div>
 </form>

 <% if (listings.length === 0) { %>
   <p class="muted">条件に合う出品が見つかりませんでした。</p>
 <% } else { %>
   <div class="listing-grid">
     <% listings.forEach(listing => { %>
       <a class="listing-card" href="/listings/<%= listing.id %>">
         <div class="listing-card-image">No Image</div>
         <div class="listing-card-body">
           <div class="listing-card-title"><%= listing.book.title %></div>
           <div class="listing-card-meta">
             <%= listing.book.author %> ・ 状態: <%= listing.condition %><br>
             出品者: <%= listing.seller.name %>
           </div>
           <% if (listing.listingType === 'FIXED') { %>
             <span class="price-tag"><%= listing.price %>円</span>
           <% } else { %>
             <span class="price-tag">現在 <%= listing.currentPrice %>円</span>
           <% } %>
         </div>
       </a>
     <% }) %>
   </div>
 <% } %>

 <p><a href="/books">教科書マスタを見る</a></p>

<%- include('partials/foot') %>
