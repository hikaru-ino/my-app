<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>教科書一覧</title>
</head>
<body>
 <h1>教科書一覧</h1>
 <ul>
  <% books.forEach(book => { %>
    <li>
      <%= book.title %> / <%= book.author %> — <%= book.price %>円
      <% if (book.course) { %>(<%= book.course %>)<% } %>
    </li>
  <% }) %>
 </ul>

 <h2>出品する</h2>
 <form action="/books" method="post">
  <input type="text" name="title" placeholder="タイトル" required>
  <input type="text" name="author" placeholder="著者" required>
  <input type="number" name="price" placeholder="価格" required>
  <input type="text" name="course" placeholder="授業名(任意)">
  <button type="submit">出品</button>
 </form>

</body>
</html>
