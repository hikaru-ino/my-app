<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>教科書マスタ</title>
</head>
<body>
 <%- include('partials/nav') %>

 <h1>教科書マスタ</h1>
 <p>ここは教科書そのもの(タイトル・著者など)の情報を管理する一覧です。実際の売買は<a href="/listings">出品一覧</a>から行います。</p>

 <% if (error) { %>
   <p style="color: red;"><%= error %></p>
 <% } %>

 <ul>
  <% books.forEach(book => { %>
    <li>
      <%= book.title %> / <%= book.author %>
      <% if (book.publisher) { %>(<%= book.publisher %>)<% } %>
      <% if (book.edition) { %> <%= book.edition %><% } %>
      <% if (book.isbn) { %> [ISBN: <%= book.isbn %>]<% } %>

      <% if (book.courses.length > 0) { %>
        <br>使用授業:
        <% book.courses.forEach((cb, i) => { %><%= i > 0 ? ', ' : '' %><%= cb.course.name %><% if (cb.course.year || cb.course.term) { %>(<%= [cb.course.year, cb.course.term].filter(Boolean).join(' ') %>)<% } %><% }) %>
      <% } %>

      <% if (currentUser) { %>
        <br>
        <form action="/books/<%= book.id %>/courses" method="post" style="display:inline">
          <select name="courseId" required>
            <option value="">授業を選択して紐付ける</option>
            <% courses.forEach(course => { %>
              <option value="<%= course.id %>">
                <%= course.name %><% if (course.year || course.term) { %> (<%= [course.year, course.term].filter(Boolean).join(' ') %>)<% } %>
              </option>
            <% }) %>
          </select>
          <button type="submit">紐付ける</button>
        </form>
      <% } %>
    </li>
  <% }) %>
 </ul>

 <% if (currentUser) { %>
   <h2>教科書を登録する</h2>
   <form action="/books" method="post">
    <input type="text" name="title" placeholder="タイトル" required>
    <input type="text" name="author" placeholder="著者" required>
    <input type="text" name="publisher" placeholder="出版社(任意)">
    <input type="text" name="edition" placeholder="版(任意)">
    <input type="text" name="isbn" placeholder="ISBN(任意)">
    <button type="submit">登録</button>
   </form>
 <% } else { %>
   <p>教科書を登録するには<a href="/login">ログイン</a>してください。</p>
 <% } %>

</body>
</html>
