<%- include('partials/head', { title: conversation.listing.book.title + 'についての会話' }) %>

 <h1><%= conversation.listing.book.title %>についての会話</h1>
 <% const isBuyer = conversation.buyerId === currentUser.id; %>
 <% const counterpartId = isBuyer ? conversation.listing.sellerId : conversation.buyerId; %>
 <% const counterpart = isBuyer ? conversation.listing.seller.name : conversation.buyer.name; %>
 <p>
   相手: <a href="/users/<%= counterpartId %>"><%= counterpart %>さん</a>
   ・ <a href="/listings/<%= conversation.listing.id %>">出品詳細を見る</a>
 </p>

 <div class="panel">
   <% if (conversation.messages.length === 0) { %>
     <p class="muted">まだメッセージがありません。</p>
   <% } %>
   <% conversation.messages.forEach(m => { %>
     <div class="message <%= m.senderId === currentUser.id ? 'message-mine' : 'message-theirs' %>">
       <div class="message-meta"><strong><%= m.sender.name %></strong> <span class="muted"><%= m.createdAt.toLocaleString('ja-JP') %></span></div>
       <div class="message-body"><%= m.body %></div>
     </div>
   <% }) %>
 </div>

 <% if (error) { %>
   <div class="alert-error"><%= error %></div>
 <% } %>

 <form action="/conversations/<%= conversation.id %>/messages" method="post" class="stack-form">
   <div class="field">
     <label for="body">メッセージ</label>
     <textarea id="body" name="body" required></textarea>
   </div>
   <button type="submit" class="btn">送信</button>
 </form>

 <p><a href="/conversations">会話一覧に戻る</a></p>

<%- include('partials/foot') %>
