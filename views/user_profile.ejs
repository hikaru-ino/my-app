<%- include('partials/head', { title: profileUser.name + 'さんの評価' }) %>

 <h1><%= profileUser.name %>さん</h1>

 <div class="panel">
   <% if (reviewCount === 0) { %>
     <p class="muted">まだ評価がありません。</p>
   <% } else { %>
     <p class="rating">★<%= averageScore.toFixed(1) %> <span class="muted">(<%= reviewCount %>件)</span></p>
   <% } %>
 </div>

 <h2>受け取ったレビュー</h2>
 <% if (reviews.length === 0) { %>
   <p class="muted">まだレビューがありません。</p>
 <% } else { %>
   <% reviews.forEach(review => { %>
     <div class="list-row">
       <div class="list-row-main">
         <div><span class="rating">★<%= review.score %></span> <%= review.reviewer.name %>さん</div>
         <div class="muted"><%= review.order.listing.book.title %> ・ <%= review.createdAt.toLocaleString('ja-JP') %></div>
         <% if (review.comment) { %><p><%= review.comment %></p><% } %>
       </div>
     </div>
   <% }) %>
 <% } %>

<%- include('partials/foot') %>
