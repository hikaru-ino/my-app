<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>ユーザー一覧</title>
</head>
<body>
 <ul>
  <% users.forEach(user => { %>
    <li><%= user.name %> (<%= user.age ? user.age + '歳' : '年齢不詳' %>)</li>
  <% }) %>
 </ul>

 <form action="/users" method="post">
  <input type="text" name="name" placeholder="名前" required>
  <input type="number" name="age" placeholder="年齢">
  <button type="submit">追加</button>
 </form>

</body>
</html>
