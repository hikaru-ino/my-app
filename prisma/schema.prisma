// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  passwordHash      String
  name              String
  emailVerified     Boolean  @default(false)
  verificationToken String?
  createdAt         DateTime @default(now())

  listings      Listing[]      @relation("ListingSeller")
  wonListings   Listing[]      @relation("ListingWinner")
  bids          Bid[]
  conversations Conversation[]
  messages      Message[]
  orders        Order[]
}

model Book {
  id        Int      @id @default(autoincrement())
  isbn      String?  @unique
  title     String
  author    String
  publisher String?
  edition   String?
  createdAt DateTime @default(now())

  courses  CourseBook[]
  listings Listing[]
}

model Course {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  teacher   String?
  year      Int?
  term      String?
  createdAt DateTime @default(now())

  books CourseBook[]
}

model CourseBook {
  id       Int @id @default(autoincrement())
  bookId   Int
  courseId Int

  book   Book   @relation(fields: [bookId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([bookId, courseId])
  @@index([courseId])
}

enum ListingType {
  FIXED
  AUCTION
}

enum ListingStatus {
  ACTIVE // 公開中
  IN_TRANSACTION // 取引中
  SOLD // 売却済
  CANCELLED // 取消
}

model Listing {
  id          Int           @id @default(autoincrement())
  bookId      Int
  sellerId    Int
  listingType ListingType
  status      ListingStatus @default(ACTIVE)
  condition   String // BOOK_CONDITIONSで検証(constants.ts)
  description String?

  price         Int? // FIXEDのみ
  startingPrice Int? // AUCTIONのみ
  currentPrice  Int? // AUCTIONのみ。Bid作成時に更新
  auctionEndAt  DateTime? // AUCTIONのみ
  winnerId      Int? // AUCTIONのみ。終了確定時に最高額入札者を記録

  createdAt DateTime @default(now())

  book          Book           @relation(fields: [bookId], references: [id])
  seller        User           @relation("ListingSeller", fields: [sellerId], references: [id])
  winner        User?          @relation("ListingWinner", fields: [winnerId], references: [id])
  bids          Bid[]
  conversations Conversation[]
  order         Order?

  @@index([status, createdAt(sort: Desc)])
  @@index([bookId])
}

model Bid {
  id        Int      @id @default(autoincrement())
  listingId Int
  bidderId  Int
  amount    Int
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  bidder  User    @relation(fields: [bidderId], references: [id])
}

model Conversation {
  id        Int      @id @default(autoincrement())
  listingId Int
  buyerId   Int // 質問した側(出品者はlisting.sellerIdを参照)
  createdAt DateTime @default(now())

  listing  Listing   @relation(fields: [listingId], references: [id])
  buyer    User      @relation(fields: [buyerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int
  senderId       Int
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

enum Campus {
  MITA
  HIYOSHI
  YAGAMI
  SFC
  SHINANOMACHI
}

enum OrderStatus {
  PENDING // 待ち合わせ調整中
  COMPLETED // 取引完了
  CANCELLED // 取消。Listingは復帰させず、再出品は新規Listingで行う
}

model Order {
  id        Int         @id @default(autoincrement())
  listingId Int         @unique
  buyerId   Int
  price     Int // 確定価格のスナップショット(FIXEDはlisting.price、AUCTIONは落札額)
  status    OrderStatus @default(PENDING)

  campus       Campus?
  meetupDetail String?
  meetupAt     DateTime?

  buyerConfirmedAt  DateTime?
  sellerConfirmedAt DateTime?

  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@index([buyerId])
}
