// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  passwordHash      String
  name              String
  emailVerified     Boolean  @default(false)
  verificationToken String?
  createdAt         DateTime @default(now())

  listings Listing[]
  bids     Bid[]
}

model Book {
  id        Int      @id @default(autoincrement())
  isbn      String?  @unique
  title     String
  author    String
  publisher String?
  edition   String?
  createdAt DateTime @default(now())

  courses  CourseBook[]
  listings Listing[]
}

model Course {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  teacher   String?
  year      Int?
  term      String?
  createdAt DateTime @default(now())

  books CourseBook[]
}

model CourseBook {
  id       Int @id @default(autoincrement())
  bookId   Int
  courseId Int

  book   Book   @relation(fields: [bookId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([bookId, courseId])
  @@index([courseId])
}

enum ListingType {
  FIXED
  AUCTION
}

enum ListingStatus {
  ACTIVE // 公開中
  IN_TRANSACTION // 取引中
  SOLD // 売却済
  CANCELLED // 取消
}

model Listing {
  id          Int           @id @default(autoincrement())
  bookId      Int
  sellerId    Int
  listingType ListingType
  status      ListingStatus @default(ACTIVE)
  condition   String // BOOK_CONDITIONSで検証(constants.ts)
  description String?

  price         Int? // FIXEDのみ
  startingPrice Int? // AUCTIONのみ
  currentPrice  Int? // AUCTIONのみ。Bid作成時に更新
  auctionEndAt  DateTime? // AUCTIONのみ

  createdAt DateTime @default(now())

  book   Book @relation(fields: [bookId], references: [id])
  seller User @relation(fields: [sellerId], references: [id])
  bids   Bid[]

  @@index([status, createdAt(sort: Desc)])
  @@index([bookId])
}

model Bid {
  id        Int      @id @default(autoincrement())
  listingId Int
  bidderId  Int
  amount    Int
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  bidder  User    @relation(fields: [bidderId], references: [id])
}
